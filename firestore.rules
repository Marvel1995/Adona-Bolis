rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Role determination (Simplified)
    function isAdmin() { return isVerified() && request.auth.token.email == 'hernandezalexis997@gmail.com'; }
    function isAuthorized() { return isVerified(); }

    // -------------------------------------------------------------------------
    // VALIDATION HELPERS
    // -------------------------------------------------------------------------
    function isValidIngredient(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100
          && data.unit in ['kg', 'g', 'l', 'ml', 'unit']
          && data.stock is number
          && data.costPerUnit is number && data.costPerUnit >= 0;
    }

    function isValidRecipe(data) {
      return data.name is string && data.name.size() > 0
          && data.baseType in ['agua', 'leche']
          && data.ingredients is list
          && data.yieldLitros is number && data.yieldLitros > 0
          && (data.get('priceRetail', 0) is number)
          && (data.get('priceWholesale', 0) is number);
    }

    function isValidProduct(data) {
      return data.flavor is string && data.flavor.size() > 0 && data.flavor.size() < 100
          && data.stock is number
          && data.priceWholesale is number && data.priceWholesale >= 0
          && data.priceRetail is number && data.priceRetail >= 0
          && (data.get('reorderPoint', 0) is number);
    }

    function isValidTask(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200
          && data.dueDate is string && data.dueDate.size() > 0
          && data.assignee in ['General', 'Mauricio', 'Silvia', 'Alexis']
          && data.status in ['pending', 'completed']
          && (data.get('description', '') is string && data.get('description', '').size() < 1000);
    }

    function isValidNote(data) {
      return data.content is string && data.content.size() < 10000;
    }

    function isValidSale(data) {
      return data.total is number && data.total >= 0
          && data.status in ['paid', 'pending', 'scheduled']
          && data.items is list
          && (data.get('deliveryDate', '') is string)
          && (data.get('deliveryTime', '') is string)
          && (data.get('deliveryAddress', '') is string)
          && (data.get('customerName', '') is string);
    }

    // -------------------------------------------------------------------------
    // RULES
    // -------------------------------------------------------------------------
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users (Profiles)
    match /users/{userId} {
      allow get: if isAuthorized() && (request.auth.uid == userId || isAdmin());
      allow list: if isAuthorized();
      allow write: if isAuthorized();
    }

    // Ingredients
    match /ingredients/{id} {
      allow read: if isAuthorized();
      allow write: if isAuthorized() && isValidIngredient(incoming());
      allow delete: if isAdmin();
    }

    // Recipes
    match /recipes/{id} {
      allow read: if isAuthorized();
      allow write: if isAuthorized() && isValidRecipe(incoming());
      allow delete: if isAdmin();
    }

    // Productions
    match /productions/{id} {
      allow read: if isAuthorized();
      allow write: if isAuthorized();
      allow delete: if isAdmin();
    }

    // Products
    match /products/{id} {
      allow read: if isAuthorized();
      allow write: if isAuthorized(); 
    }

    // Customers
    match /customers/{id} {
      allow read: if isAuthorized();
      allow write: if isAuthorized();
    }

    // Sales
    match /sales/{id} {
      allow read: if isAuthorized();
      allow create: if isAuthorized() && isValidSale(incoming());
      allow update: if isAuthorized();
      allow delete: if isAdmin();
    }

    // Expenses
    match /expenses/{id} {
      allow read: if isAuthorized();
      allow write: if isAuthorized();
    }

    // Settings
    match /settings/{id} {
      allow read: if isAuthorized();
      allow write: if isAdmin();
    }

    // Shared Notepad
    match /settings/notes {
      allow read: if isAuthorized();
      allow write: if isAuthorized() && isValidNote(incoming());
    }

    // Tasks
    match /tasks/{id} {
      allow read: if isAuthorized();
      allow write: if isAuthorized() && isValidTask(incoming());
      allow delete: if isAuthorized();
    }
  }
}
